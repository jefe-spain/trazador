    "ink": "^5.2.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "meow": "^13.0.0",
    "react": "^18.3.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
