{
  "name": "trazador",
  "version": "0.3.0",
  "description": "Agent workflow for project management — connect Claude Code, Codex, or OpenCode to Linear and GitHub Issues.",
  "type": "module",
  "bin": {
    "trazador": "./cli/dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx cli/src/cli.tsx",
    "postbuild": "chmod +x cli/dist/cli.js"
  },
  "files": [
    "cli/dist",
    "providers",
    "agents"
  ],
  "author": {
    "name": "Jose Fernandez",
    "url": "https://github.com/jefernandez"
  },
  "repository": "https://github.com/jefe-spain/trazador",
  "license": "MIT",
  "publishConfig": {
    "provenance": true
  },
  "keywords": [
    "linear",
    "github-issues",
    "agents",
    "workflow",
    "project-management",
    "claude-code",
    "codex",
    "opencode",
    "cli"
  ],
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "ink": "^5.2.0",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "meow": "^13.0.0",
    "react": "^18.3.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
