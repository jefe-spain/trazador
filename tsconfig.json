{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "cli/dist",
    "rootDir": "cli/src",
    "declaration": false
  },
  "include": ["cli/src/**/*"]
}
